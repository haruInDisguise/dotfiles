#!/usr/bin/zsh
# Launch librespot
# UNSAFE: Leaks account credentials into the
#         process stack (cmdline)

emulate -L zsh

local -a cmd_args=(
  --cache     "$XDG_CACHE_HOME/librespot"
  --name      "$(uname -n)"
  --bitrate   320
  --backend   rodio
  --username  "$(pass web/spotify/username)" # AHHHHHHHHHHHHH
  --password  "$(pass web/spotify/password)"
  --onevent   "$USER_CONF_SCRIPTS_ROOT/scripts/handle_event_librespot"
)

exec librespot ${(u)cmd_args}
